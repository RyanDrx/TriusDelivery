---
import Section from '@components/Section.astro';

interface FAQItem {
    question: string;
    answer: string;
}

interface Props {
    heading: string;
    intro?: string;
    items: readonly FAQItem[];
    class?: string;
}

const { heading, intro, items, class: className } = Astro.props;
---

<Section class:list={['bg-slate-50', className]}>
    <div class="max-w-4xl mx-auto">
        <div class="text-center">
            <div
                class="inline-flex items-center gap-2 rounded-full border border-primary/15 bg-primary/5 px-4 py-2 text-xs font-bold tracking-[0.16em] uppercase text-primary"
            >
                <iconify-icon icon="heroicons:question-mark-circle" width="18" height="18"></iconify-icon>
                Frequently Asked Questions
            </div>
            <h2 class="mt-5 text-3xl md:text-4xl font-black text-slate-900 leading-tight">{heading}</h2>
            {intro && <p class="mt-5 text-lg leading-8 text-slate-600">{intro}</p>}
        </div>

        <div class="mt-10 space-y-4">
            {
                items.map((item) => (
                    <details class="group overflow-hidden rounded-[1.5rem] border border-slate-200 bg-white shadow-[0_20px_60px_-44px_rgba(15,23,42,0.35)]">
                        <summary class="faq-summary flex cursor-pointer list-none items-center justify-between gap-4 px-6 py-5 text-left font-bold text-slate-900">
                            <span>{item.question}</span>
                            <span class="flex h-9 w-9 flex-shrink-0 items-center justify-center rounded-full bg-primary/10 text-primary transition-transform duration-300 group-open:rotate-45">
                                +
                            </span>
                        </summary>
                        <div class="px-6 pb-6 text-base leading-7 text-slate-600">
                            <p>{item.answer}</p>
                        </div>
                    </details>
                ))
            }
        </div>
    </div>
</Section>

<style>
    .faq-summary::-webkit-details-marker {
        display: none;
    }
</style>
