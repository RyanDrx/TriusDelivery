---
import { safeMarkdown } from '@utils/markdown';
import { type Footer } from 'types';

interface Props extends Footer {
    'data-sb-field-path'?: string;
}

const { text, 'data-sb-field-path': fieldPath } = Astro.props;
---

<footer
    class='footer-wrapper bg-neutral-dark text-white'
    data-sb-field-path={fieldPath}
>
    <!-- Main Footer Content -->
    <div class='max-w-7xl mx-auto px-4 py-16 lg:px-6 lg:py-20'>
        <!-- Top Section -->
        <div class='grid grid-cols-1 lg:grid-cols-4 gap-12 mb-12'>
            <!-- Company Info -->
            <div class='lg:col-span-2 space-y-6'>
                <!-- Logo/Brand -->
                <div class='flex items-center gap-4 mb-6'>
                    <img
                        src='/logos/Trius_Logo.svg'
                        alt='Trius LLC - Medical Courier Services'
                        class='w-8 h-8 brightness-0 invert object-contain flex-shrink-0'
                    />
                    <div>
                        <h3 class='text-2xl font-bold text-white font-brand'>TRIUS LLC</h3>
                        <p class='text-sm text-white/70 font-medium'>Medical Logistics Experts</p>
                    </div>
                </div>

                <p class='text-white/80 leading-relaxed max-w-md'>
                    Professional medical courier services specializing in reliable, compliant delivery across Washington, Oregon, Idaho,
                    Montana, and California. Founded in 2022 and based in Tacoma, Washington.
                </p>

                <!-- Trust Badges -->
                <div class='flex flex-wrap gap-3 mt-6'>
                    <span class='inline-flex items-center gap-2 px-3 py-2 bg-white/10 rounded-lg text-sm font-medium text-white/90 border border-white/20'>
                        <iconify-icon icon='material-symbols:verified-user' width='18' height='18'></iconify-icon>
                        TSA Verified
                    </span>
                    <span class='inline-flex items-center gap-2 px-3 py-2 bg-white/10 rounded-lg text-sm font-medium text-white/90 border border-white/20'>
                        <iconify-icon icon='material-symbols:security' width='18' height='18'></iconify-icon>
                        Insured & Bonded
                    </span>
                    <span class='inline-flex items-center gap-2 px-3 py-2 bg-white/10 rounded-lg text-sm font-medium text-white/90 border border-white/20'>
                        <iconify-icon icon='twemoji:flag-for-flag-united-states' width='18' height='18'></iconify-icon>
                        US Based
                    </span>
                    <span class='inline-flex items-center gap-2 px-3 py-2 bg-white/10 rounded-lg text-sm font-medium text-white/90 border border-white/20'>
                        <iconify-icon icon='material-symbols:apartment' width='18' height='18'></iconify-icon>
                        Small Business
                    </span>
                </div>
            </div>

            <!-- Quick Links -->
            <div class='space-y-6'>
                <h4 class='text-lg font-semibold text-white border-l-4 border-secondary pl-4'>Quick Links</h4>
                <nav class='space-y-2'>
                    <a href='/services' class='flex items-center gap-2 text-white/80 hover:text-white transition-colors py-1.5 text-sm'>
                        Our Services
                    </a>
                    <a href='/about' class='flex items-center gap-2 text-white/80 hover:text-white transition-colors py-1.5 text-sm'>
                        About Us
                    </a>
                    <a href='/coverage' class='flex items-center gap-2 text-white/80 hover:text-white transition-colors py-1.5 text-sm'>
                        Coverage Areas
                    </a>
                    <a href='/contact' class='flex items-center gap-2 text-white/80 hover:text-white transition-colors py-1.5 text-sm'>
                        Contact
                    </a>
                    <a href='/sitemap-index.xml' class='flex items-center gap-2 text-white/80 hover:text-white transition-colors py-1.5 text-sm'>
                        Sitemap
                    </a>
                </nav>
            </div>

            <!-- Contact Information -->
            <div class='space-y-6'>
                <h4 class='text-lg font-semibold text-white border-l-4 border-secondary pl-4'>Contact Info</h4>
                <div class='space-y-4'>
                    <!-- Emergency STAT Line -->
                    <div class='flex items-start gap-3 p-3 bg-accent/15 rounded-lg border border-accent/25'>
                        <div class='w-9 h-9 rounded-lg bg-accent flex items-center justify-center flex-shrink-0'>
                            <iconify-icon icon='material-symbols:emergency' width='18' height='18' class='text-white'></iconify-icon>
                        </div>
                        <div>
                            <p class='text-white font-semibold text-sm'>24/7 STAT Emergency</p>
                            <a href='tel:1-800-TRIUS-911' class='text-white/90 hover:text-white transition-colors text-sm'>
                                1-800-TRIUS-911
                            </a>
                        </div>
                    </div>

                    <!-- Email -->
                    <div class='flex items-start gap-3'>
                        <div class='w-9 h-9 rounded-lg bg-white/10 flex items-center justify-center flex-shrink-0'>
                            <iconify-icon icon='material-symbols:mail' width='18' height='18' class='text-white'></iconify-icon>
                        </div>
                        <div>
                            <p class='text-white/60 text-xs'>Email</p>
                            <a href='mailto:Triusllccouriers@outlook.com' class='text-white/90 hover:text-white transition-colors text-sm'>
                                Triusllccouriers@outlook.com
                            </a>
                        </div>
                    </div>

                    <!-- Address -->
                    <div class='flex items-start gap-3'>
                        <div class='w-9 h-9 rounded-lg bg-white/10 flex items-center justify-center flex-shrink-0'>
                            <iconify-icon icon='material-symbols:location-on' width='18' height='18' class='text-white'></iconify-icon>
                        </div>
                        <div>
                            <p class='text-white/60 text-xs'>Address</p>
                            <address class='text-white/90 text-sm not-italic'>
                                618 160th Street Ct E, Tacoma, WA 98445
                            </address>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Service Areas -->
        <div class='border-t border-white/20 pt-12 mb-12'>
            <div class='text-center'>
                <h4 class='text-xl font-bold text-white mb-4'>Service Coverage Areas</h4>
                <p class='text-white/70 text-sm mb-6'>Comprehensive medical logistics across the Pacific Northwest &amp; California</p>
                <div class='flex flex-wrap justify-center gap-3'>
                    <span class='px-4 py-2 bg-white/10 rounded-lg text-sm font-medium text-white/90 border border-white/20'>Washington</span>
                    <span class='px-4 py-2 bg-white/10 rounded-lg text-sm font-medium text-white/90 border border-white/20'>Oregon</span>
                    <span class='px-4 py-2 bg-white/10 rounded-lg text-sm font-medium text-white/90 border border-white/20'>Idaho</span>
                    <span class='px-4 py-2 bg-white/10 rounded-lg text-sm font-medium text-white/90 border border-white/20'>Montana</span>
                    <span class='px-4 py-2 bg-white/10 rounded-lg text-sm font-medium text-white/90 border border-white/20'>California</span>
                </div>
                <a href='/coverage' class='inline-flex items-center gap-2 mt-4 text-sm text-white/80 hover:text-white transition-colors font-medium'>
                    <iconify-icon icon='material-symbols:map' width='16' height='16'></iconify-icon>
                    View full coverage map
                </a>
            </div>
        </div>

        <!-- Bottom Bar -->
        <div class='border-t border-white/20 pt-8 flex flex-col lg:flex-row justify-between items-center gap-6'>
            <div class='text-sm text-white/60 text-center lg:text-left'>
                © {new Date().getFullYear()} Trius LLC. All rights reserved. |
                <a href='/privacy' class='hover:text-white transition-colors'>Privacy Policy</a> |
                <a href='/terms' class='hover:text-white transition-colors'>Terms of Service</a>
            </div>

            <span class='text-sm text-white/60'>Professional Medical Logistics Since 2022</span>
        </div>

        <!-- Custom text from CMS if available -->
        {
            text && (
                <div
                    class='mt-8 text-center text-white/80 prose prose-invert max-w-none'
                    data-sb-field-path='.text'
                    set:html={safeMarkdown(text)}
                />
            )
        }
    </div>

    <!-- RNDTND Credit -->
    <div class='border-t border-white/10'>
        <div class='max-w-7xl mx-auto px-4 py-3 text-center'>
            <a
                href='https://rndtnd.com'
                target='_blank'
                rel='noopener noreferrer'
                class='group inline-flex items-center gap-2 text-white/40 hover:text-white/70 transition-colors duration-300'
            >
                <img
                    src='https://rndtnd.com/images/logos/logo_rocket.svg'
                    alt='RNDTND'
                    class='h-5 w-5 opacity-60 group-hover:opacity-100 transition-opacity'
                />
                <span class='text-xs font-medium'>Crafted by RND_TND</span>
            </a>
        </div>
    </div>
</footer>

<style>
    /* Responsive adjustments */
    @media (max-width: 768px) {
        .footer-wrapper .grid {
            gap: 2rem;
        }
    }
</style>
