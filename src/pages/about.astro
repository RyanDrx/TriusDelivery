---
import Layout from '@layouts/Layout.astro';
import SEO from '@components/SEO.astro';
import Hero from '@components/Hero.astro';
import Cta from '@components/Cta.astro';
import { localBusiness, webSite } from '../lib/schema.ts';
import WaveClip from '@components/WaveClip.astro';

const heroData = {
    title: 'About Trius LLC',
    subtitle: 'Built from Real-World Experience in Medical Logistics',
    body: 'Founded with a simple mission: to provide reliable, professional, and responsive courier services tailored specifically to the medical and healthcare industry.'
};

const ctaData = {
    title: 'Partner with Trius LLC Today',
    body: 'Ready to experience reliable, compliant medical courier services? Contact us to discuss your specific needs and discover how we can improve your medical logistics.',
    primaryAction: {
        label: 'Request Quote',
        url: '/contact'
    },
    secondaryAction: {
        label: 'View Our Services',
        url: '/services'
    }
};

const schema = {
    '@context': 'https://schema.org',
    '@graph': [localBusiness(), webSite()]
};
---

<Layout
    title='About Us - Trius LLC Medical Courier Services'
    description="Learn about Trius LLC's mission to provide reliable, HIPAA/OSHA compliant medical courier services across WA, OR, ID, MT, and CA. Specialized expertise in medical logistics."
>
    <Fragment slot='head'>
        <SEO
            title='About Us - Trius LLC Medical Courier Services'
            description="Learn about Trius LLC's mission to provide reliable, HIPAA/OSHA compliant medical courier services across WA, OR, ID, MT, and CA. Specialized expertise in medical logistics."
            graph={schema}
        />
    </Fragment>

    <Hero
        backgroundImage='/Images/medical back stehescope.webp'
        overlayClass='bg-gradient-to-r from-primary/80 via-primary/60 to-secondary/70'
        minHeight='min-h-[70vh]'
        useWaveClip={true}
    >
        <div class='text-center max-w-4xl mx-auto'>
            <h1 class='text-4xl md:text-6xl font-bold text-white mb-6'>
                {heroData.title}
            </h1>
            <p class='text-xl md:text-2xl text-gray-200 mb-4'>
                {heroData.subtitle}
            </p>
            <p class='text-lg text-gray-300 mb-8'>
                {heroData.body}
            </p>
            <a
                href='/contact'
                class='inline-block px-8 py-3 bg-primary text-white font-semibold rounded-lg hover:bg-primary/90 transition-colors'
            >
                Get Started
            </a>
        </div>
    </Hero>
    <!-- Our Story -->
    <section class='py-20 relative overflow-hidden'>
        <div class='max-w-7xl mx-auto px-4 lg:px-6 relative z-10'>
            <div class='grid lg:grid-cols-2 gap-12 items-center'>
                <div>
                    <h2 class='text-3xl md:text-4xl font-bold text-gray-900 mb-6'>Our Story</h2>
                    <p class='text-lg text-gray-600 mb-6'>
                        After years of working in orthopedic operations and logistics, we saw firsthand the gaps in traditional delivery
                        services&mdash;missed time windows, lack of accountability, and limited understanding of how critical medical
                        deliveries truly are. Trius LLC was created to bridge that gap.
                    </p>
                    <p class='text-lg text-gray-600 mb-6'>
                        We specialize in the safe and efficient transportation of medical devices, surgical instruments, and time-sensitive
                        healthcare materials. Our drivers are trained in industry systems such as SetTrax and Casechek, understand hospital
                        workflows, and are experienced with everything from routine deliveries to urgent, same-day case support.
                    </p>
                    <p class='text-lg text-gray-600 mb-8'>
                        With TSA-verified drivers and access to secure facilities including airports and military bases, we provide a level
                        of reliability our clients can count on.
                    </p>
                    <div class='bg-primary/5 border-l-4 border-primary p-6 rounded-r-lg'>
                        <p class='text-lg text-gray-700 italic'>
                            "At Trius, we don't just move packages&mdash;we support patient care by ensuring the right equipment gets to the
                            right place, at the right time."
                        </p>
                    </div>
                </div>
                <div class='bg-gray-50 p-8 rounded-lg'>
                    <h3 class='text-2xl font-bold text-gray-900 mb-6'>Meet Our Team</h3>
                    <div class='space-y-6'>
                        <div class='flex items-start space-x-4'>
                            <!-- TODO: Replace with Kevin's headshot when available -->
                            <div class='w-16 h-16 bg-primary/10 rounded-full flex items-center justify-center'>
                                <svg class='w-8 h-8 text-primary' fill='currentColor' viewBox='0 0 20 20'>
                                    <path fill-rule='evenodd' d='M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z' clip-rule='evenodd'>
                                    </path>
                                </svg>
                            </div>
                            <div>
                                <h4 class='font-semibold text-gray-900'>Kevin Hyatt</h4>
                                <p class='text-sm text-gray-600'>Founder</p>
                                <p class='text-sm text-gray-500 mt-2'>With years of experience in orthopedic operations and logistics, Kevin founded Trius LLC to deliver the reliability and accountability that medical professionals deserve.</p>
                            </div>
                        </div>
                    </div>

                    <!-- Photo Gallery - action shots & customer photos -->
                    <div class='mt-8 pt-6 border-t border-gray-200'>
                        <h4 class='font-semibold text-gray-900 mb-4'>In the Field</h4>
                        <!-- TODO: Replace with Kevin's hand-to-hand action shots and happy customer photos -->
                        <div class='grid grid-cols-2 gap-3'>
                            <div class='aspect-[4/3] rounded-lg overflow-hidden'>
                                <img
                                    src='/Images/Courier handoff.webp'
                                    alt='Trius courier completing a delivery handoff'
                                    class='w-full h-full object-cover'
                                    loading='lazy'
                                />
                            </div>
                            <div class='aspect-[4/3] rounded-lg overflow-hidden'>
                                <img
                                    src='/Images/vehicle package.webp'
                                    alt='Trius delivery vehicle loaded with medical equipment'
                                    class='w-full h-full object-cover'
                                    loading='lazy'
                                />
                            </div>
                        </div>
                        <p class='text-xs text-gray-400 mt-2 text-center'>More photos coming soon</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Mission & Values -->
    <section class='py-20 bg-gradient-to-br from-slate-50 via-primary/5 to-secondary/5'>
        <div class='max-w-7xl mx-auto px-4 lg:px-6'>
            <div class='text-center mb-12'>
                <h2 class='text-3xl md:text-4xl font-bold text-gray-900 mb-4'>Our Mission & Values</h2>
                <p class='text-xl text-gray-600'>What drives us every day</p>
            </div>
            <div class='grid md:grid-cols-3 gap-8'>
                <div class='bg-white p-6 rounded-lg shadow-sm text-center'>
                    <div class='w-16 h-16 bg-primary/10 rounded-full flex items-center justify-center mx-auto mb-4'>
                        <svg class='w-8 h-8 text-primary' fill='none' stroke='currentColor' viewBox='0 0 24 24'>
                            <path
                                stroke-linecap='round'
                                stroke-linejoin='round'
                                stroke-width='2'
                                d='M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z'
                            >
                            </path>
                        </svg>
                    </div>
                    <h3 class='text-xl font-semibold mb-4 text-gray-900'>Reliability First</h3>
                    <p class='text-gray-600'>
                        We understand that medical logistics can be life-critical. Our commitment to reliability means your shipments arrive
                        on time, every time, with complete chain-of-custody documentation.
                    </p>
                </div>
                <div class='bg-white p-6 rounded-lg shadow-sm text-center'>
                    <div class='w-16 h-16 bg-primary/10 rounded-full flex items-center justify-center mx-auto mb-4'>
                        <svg class='w-8 h-8 text-primary' fill='none' stroke='currentColor' viewBox='0 0 24 24'>
                            <path
                                stroke-linecap='round'
                                stroke-linejoin='round'
                                stroke-width='2'
                                d='M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z'
                            >
                            </path>
                        </svg>
                    </div>
                    <h3 class='text-xl font-semibold mb-4 text-gray-900'>Compliance Focused</h3>
                    <p class='text-gray-600'>
                        HIPAA and OSHA compliance isn't just a requirement—it's our foundation. We maintain the highest standards for secure
                        handling of medical specimens and equipment.
                    </p>
                </div>
                <div class='bg-white p-6 rounded-lg shadow-sm text-center'>
                    <div class='w-16 h-16 bg-primary/10 rounded-full flex items-center justify-center mx-auto mb-4'>
                        <svg class='w-8 h-8 text-primary' fill='none' stroke='currentColor' viewBox='0 0 24 24'>
                            <path
                                stroke-linecap='round'
                                stroke-linejoin='round'
                                stroke-width='2'
                                d='M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z'
                            >
                            </path>
                        </svg>
                    </div>
                    <h3 class='text-xl font-semibold mb-4 text-gray-900'>Technology Driven</h3>
                    <p class='text-gray-600'>
                        Real-time tracking, digital documentation, and automated notifications keep you informed every step of the way.
                        Modern technology for modern healthcare.
                    </p>
                </div>
            </div>
        </div>
    </section>

    <!-- Why Choose Us -->
    <section class='py-20 bg-white'>
        <div class='max-w-7xl mx-auto px-4 lg:px-6'>
            <div class='text-center mb-12'>
                <h2 class='text-3xl md:text-4xl font-bold text-gray-900 mb-4'>Why Choose Trius LLC?</h2>
                <p class='text-xl text-gray-600'>Experience the difference of specialized medical logistics</p>
            </div>
            <div class='grid md:grid-cols-2 lg:grid-cols-4 gap-8'>
                <div class='text-center'>
                    <div class='w-16 h-16 bg-primary/10 rounded-full flex items-center justify-center mx-auto mb-4'>
                        <svg class='w-8 h-8 text-primary' fill='none' stroke='currentColor' viewBox='0 0 24 24'>
                            <path
                                stroke-linecap='round'
                                stroke-linejoin='round'
                                stroke-width='2'
                                d='M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z'
                            >
                            </path>
                        </svg>
                    </div>
                    <h3 class='text-xl font-semibold mb-4 text-gray-900'>Specialized Expertise</h3>
                    <p class='text-gray-600'>
                        Unlike general courier services, we specialize exclusively in medical logistics. Our team understands the unique
                        requirements of healthcare deliveries.
                    </p>
                </div>
                <div class='text-center'>
                    <div class='w-16 h-16 bg-primary/10 rounded-full flex items-center justify-center mx-auto mb-4'>
                        <svg class='w-8 h-8 text-primary' fill='none' stroke='currentColor' viewBox='0 0 24 24'>
                            <path
                                stroke-linecap='round'
                                stroke-linejoin='round'
                                stroke-width='2'
                                d='M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z'
                            >
                            </path>
                            <path stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M15 11a3 3 0 11-6 0 3 3 0 016 0z'>
                            </path>
                        </svg>
                    </div>
                    <h3 class='text-xl font-semibold mb-4 text-gray-900'>Regional Coverage</h3>
                    <p class='text-gray-600'>
                        Comprehensive coverage across Washington, Oregon, Idaho, Montana, and California with local knowledge and
                        established networks.
                    </p>
                </div>
                <div class='text-center'>
                    <div class='w-16 h-16 bg-primary/10 rounded-full flex items-center justify-center mx-auto mb-4'>
                        <svg class='w-8 h-8 text-primary' fill='none' stroke='currentColor' viewBox='0 0 24 24'>
                            <path
                                stroke-linecap='round'
                                stroke-linejoin='round'
                                stroke-width='2'
                                d='M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z'
                            >
                            </path>
                        </svg>
                    </div>
                    <h3 class='text-xl font-semibold mb-4 text-gray-900'>24/7 Availability</h3>
                    <p class='text-gray-600'>
                        Medical emergencies don't wait for business hours. Our STAT services are available around the clock with rapid
                        response times.
                    </p>
                </div>
                <div class='text-center'>
                    <div class='w-16 h-16 bg-primary/10 rounded-full flex items-center justify-center mx-auto mb-4'>
                        <svg class='w-8 h-8 text-primary' fill='none' stroke='currentColor' viewBox='0 0 24 24'>
                            <path
                                stroke-linecap='round'
                                stroke-linejoin='round'
                                stroke-width='2'
                                d='M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1'
                            >
                            </path>
                        </svg>
                    </div>
                    <h3 class='text-xl font-semibold mb-4 text-gray-900'>Competitive Pricing</h3>
                    <p class='text-gray-600'>
                        Transparent, competitive pricing with no hidden fees. We offer cost-effective solutions for both one-time deliveries
                        and recurring routes.
                    </p>
                </div>
            </div>
        </div>
    </section>

    <!-- Certifications -->
    <section class='py-20 relative overflow-hidden'>
        <div class='max-w-7xl mx-auto px-4 lg:px-6 relative z-10'>
            <div class='max-w-7xl mx-auto px-4 lg:px-6'>
                <div class='text-center mb-12'>
                    <h2 class='text-3xl md:text-4xl font-bold text-gray-900 mb-4'>Certifications & Compliance</h2>
                    <p class='text-xl text-gray-600'>Meeting the highest industry standards</p>
                </div>
                <div class='grid md:grid-cols-2 lg:grid-cols-4 gap-8'>
                    <div class='bg-white p-6 rounded-lg shadow-sm text-center'>
                        <div class='w-16 h-16 bg-primary/10 rounded-full flex items-center justify-center mx-auto mb-4'>
                            <svg class='w-8 h-8 text-primary' fill='none' stroke='currentColor' viewBox='0 0 24 24'>
                                <path
                                    stroke-linecap='round'
                                    stroke-linejoin='round'
                                    stroke-width='2'
                                    d='M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z'
                                >
                                </path>
                            </svg>
                        </div>
                        <h3 class='text-xl font-semibold mb-4 text-gray-900'>HIPAA Compliance</h3>
                        <p class='text-gray-600'>
                            Full compliance with Health Insurance Portability and Accountability Act requirements for handling protected
                            health information.
                        </p>
                    </div>
                    <div class='bg-white p-6 rounded-lg shadow-sm text-center'>
                        <div class='w-16 h-16 bg-primary/10 rounded-full flex items-center justify-center mx-auto mb-4'>
                            <svg class='w-8 h-8 text-primary' fill='none' stroke='currentColor' viewBox='0 0 24 24'>
                                <path
                                    stroke-linecap='round'
                                    stroke-linejoin='round'
                                    stroke-width='2'
                                    d='M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z'
                                >
                                </path>
                            </svg>
                        </div>
                        <h3 class='text-xl font-semibold mb-4 text-gray-900'>OSHA Certification</h3>
                        <p class='text-gray-600'>
                            Occupational Safety and Health Administration certified drivers and handling procedures for safe transport of
                            medical materials.
                        </p>
                    </div>
                    <div class='bg-white p-6 rounded-lg shadow-sm text-center'>
                        <div class='w-16 h-16 bg-primary/10 rounded-full flex items-center justify-center mx-auto mb-4'>
                            <svg class='w-8 h-8 text-primary' fill='none' stroke='currentColor' viewBox='0 0 24 24'>
                                <path
                                    stroke-linecap='round'
                                    stroke-linejoin='round'
                                    stroke-width='2'
                                    d='M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z'
                                >
                                </path>
                            </svg>
                        </div>
                        <h3 class='text-xl font-semibold mb-4 text-gray-900'>DOT Regulations</h3>
                        <p class='text-gray-600'>
                            Department of Transportation compliant vehicles and drivers for interstate medical transport services.
                        </p>
                    </div>
                    <div class='bg-white p-6 rounded-lg shadow-sm text-center'>
                        <div class='w-16 h-16 bg-primary/10 rounded-full flex items-center justify-center mx-auto mb-4'>
                            <svg class='w-8 h-8 text-primary' fill='none' stroke='currentColor' viewBox='0 0 24 24'>
                                <path
                                    stroke-linecap='round'
                                    stroke-linejoin='round'
                                    stroke-width='2'
                                    d='M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z'
                                >
                                </path>
                            </svg>
                        </div>
                        <h3 class='text-xl font-semibold mb-4 text-gray-900'>Insurance Coverage</h3>
                        <p class='text-gray-600'>
                            Comprehensive commercial insurance including cargo coverage and liability protection for your peace of mind.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </section>
    <!-- CTA Section with Background -->
    <section class='relative overflow-hidden'>
        <WaveClip
            side='top'
            amplitude={1}
            baseline={95}
            waves={1.25}
            phase={0}
            samples={36}
            topBaseline={10}
            topAmplitude={1}
            topPhase={0}
            class='absolute inset-0 opacity-2 py-24'
        >
            <div class='absolute inset-0 opacity-2'>
                <div
                    class='absolute inset-0 min-h-44'
                    style='background-image: url("/Images/Courier handoff.webp"); background-size: cover; background-repeat: no-repeat; background-position: center;'
                >
                </div>
            </div>
            <div class='absolute inset-0 bg-white/60'></div>
        </WaveClip>
        <div class='relative z-10 pt-24'>
            <Cta {...ctaData} />
        </div>
    </section>
</Layout>
