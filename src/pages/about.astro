---
import Layout from '@layouts/Layout.astro';
import SEO from '@components/SEO.astro';
import Hero from '@components/Hero.astro';
import Cta from '@components/Cta.astro';
import { localBusiness, webSite } from '../lib/schema';
import WaveClip from '@components/WaveClip.astro';

const heroData = {
    title: 'About Trius LLC',
    subtitle: 'A Medical Courier Company Based in Tacoma, WA',
    body: 'We started Trius because the courier services hospitals were using kept dropping the ball. Missed windows, no tracking, drivers who didn\'t know a specimen from a package. We figured we could do better.'
};

const ctaData = {
    title: 'Want to talk about your routes?',
    body: 'Call or email. We\'ll put together a quote based on your actual volume, not a pricing calculator.',
    primaryAction: {
        label: 'Request Quote',
        url: '/contact'
    },
    secondaryAction: {
        label: 'View Our Services',
        url: '/services'
    }
};

const schema = {
    '@context': 'https://schema.org',
    '@graph': [localBusiness(), webSite()]
};
---

<Layout
    title="About Us - Trius LLC Medical Courier Services"
    description="Learn about Trius LLC's mission to provide reliable, professional medical courier services across WA, OR, ID, MT, and CA. Specialized expertise in medical logistics."
    image={{ src: '/og-image.png' }}
>
    <Fragment slot="head">
        <SEO
            title="About Us - Trius LLC Medical Courier Services"
            description="Learn about Trius LLC's mission to provide reliable, professional medical courier services across WA, OR, ID, MT, and CA. Specialized expertise in medical logistics."
            graph={schema}
        />
    </Fragment>

    <Hero
        backgroundImage="/Images/medical back stehescope.webp"
        overlayClass="bg-gradient-to-r from-primary/80 via-primary/60 to-secondary/70"
        minHeight="min-h-[70vh]"
        useWaveClip={true}
    >
        <div class="text-center max-w-4xl mx-auto">
            <h1 class="text-4xl md:text-6xl font-bold text-white mb-6">
                {heroData.title}
            </h1>
            <p class="text-xl md:text-2xl text-gray-200 mb-4">
                {heroData.subtitle}
            </p>
            <p class="text-lg text-gray-300 mb-8">
                {heroData.body}
            </p>
            <a
                href="/contact"
                class="inline-block px-8 py-3 bg-primary text-white font-semibold rounded-lg hover:bg-primary/90 transition-colors"
            >
                Get Started
            </a>
        </div>
    </Hero>
    <!-- Our Story -->
    <section class="py-20 relative overflow-hidden">
        <div class="max-w-7xl mx-auto px-4 lg:px-6 relative z-10">
            <div class="grid lg:grid-cols-2 gap-12 items-center">
                <div>
                    <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-6">Our Story</h2>
                    <p class="text-lg text-gray-600 mb-6">
                        After years of working in orthopedic operations and logistics, we saw firsthand the gaps in traditional delivery
                        services&mdash;missed time windows, lack of accountability, and limited understanding of how critical medical
                        deliveries truly are. Trius LLC was created to bridge that gap.
                    </p>
                    <p class="text-lg text-gray-600 mb-6">
                        We specialize in the safe and efficient transportation of medical devices, surgical instruments, and time-sensitive
                        healthcare materials. Our drivers are trained in industry systems such as SetTrax and Casechek, understand hospital
                        workflows, and are experienced with everything from routine deliveries to urgent, same-day case support.
                    </p>
                    <p class="text-lg text-gray-600 mb-8">
                        With TSA-verified drivers and access to secure facilities including airports and military bases, we provide a level
                        of reliability our clients can count on.
                    </p>
                    <div class="bg-primary/5 border-l-4 border-primary p-6 rounded-r-lg">
                        <p class="text-lg text-gray-700 italic">
                            "At Trius, we don't just move packages&mdash;we support patient care by ensuring the right equipment gets to the
                            right place, at the right time."
                        </p>
                    </div>
                </div>
                <div class="bg-gray-50 p-8 rounded-lg">
                    <h3 class="text-2xl font-bold text-gray-900 mb-6">Meet Our Founder</h3>
                    <div class="space-y-6">
                        <div class="flex flex-col items-center text-center">
                            <img
                                src="/kevin_profile.webp"
                                alt="Kevin Hyatt, Founder of Trius LLC"
                                class="w-72 h-72 rounded-full object-cover mb-4"
                                style="object-position: center 20%;"
                                loading="lazy"
                                decoding="async"
                                width="480"
                                height="640"
                            />
                            <h4 class="font-semibold text-gray-900 text-lg">Kevin Hyatt</h4>
                            <p class="text-sm text-gray-600">Founder</p>
                            <p class="text-sm text-gray-500 mt-2">
                                Background in orthopedic operations and medical device logistics. Started Trius in 2022 after seeing too many missed deliveries cost surgical teams time they didn't have.
                            </p>
                        </div>
                    </div>

                    <!-- Fleet Gallery -->
                    <div class="mt-8 pt-6 border-t border-gray-200">
                        <div class="flex items-center justify-between mb-4">
                            <div>
                                <div class="text-xs font-bold uppercase tracking-[0.16em] text-primary">In the Field</div>
                                <div class="text-sm text-gray-500 mt-1">A snapshot of Trius vehicles serving healthcare facilities</div>
                            </div>
                        </div>

                        <div class="grid grid-cols-1 gap-3">
                            <div class="relative rounded-2xl overflow-hidden aspect-[16/9] shadow-md">
                                <img
                                    src="/Images/trius-van-hospital.webp"
                                    alt="Trius delivery van at hospital facility"
                                    class="w-full h-full object-cover"
                                    style="object-position: center center;"
                                    loading="lazy"
                                    decoding="async"
                                    width="432"
                                    height="538"
                                />
                                <div class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-slate-950/70 to-transparent p-4">
                                    <p class="text-sm font-semibold text-white">Hospital and facility service</p>
                                </div>
                            </div>

                            <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                                <div class="relative rounded-2xl overflow-hidden aspect-[16/10] shadow-md">
                                    <img
                                        src="/Images/trius-van-office.webp"
                                        alt="Trius delivery van at office building"
                                        class="w-full h-full object-cover"
                                        style="object-position: center center;"
                                        loading="lazy"
                                        decoding="async"
                                        width="432"
                                        height="538"
                                    />
                                </div>
                                <div class="relative rounded-2xl overflow-hidden aspect-[16/10] shadow-md">
                                    <img
                                        src="/Images/trius-van-building.webp"
                                        alt="Trius delivery van at medical facility"
                                        class="w-full h-full object-cover"
                                        style="object-position: center center;"
                                        loading="lazy"
                                        decoding="async"
                                        width="432"
                                        height="538"
                                    />
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- How We Work -->
    <section class="py-20 bg-gradient-to-br from-slate-50 via-primary/5 to-secondary/5">
        <div class="max-w-7xl mx-auto px-4 lg:px-6">
            <div class="text-center mb-12">
                <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">How We Actually Work</h2>
                <p class="text-xl text-gray-600">Three things we care about. Everything else follows.</p>
            </div>
            <div class="grid md:grid-cols-3 gap-8">
                <div class="bg-white p-6 rounded-lg shadow-sm text-center">
                    <div class="w-16 h-16 bg-primary/10 rounded-full flex items-center justify-center mx-auto mb-4">
                        <iconify-icon icon="heroicons:clock" width="32" height="32" class="text-primary"></iconify-icon>
                    </div>
                    <h3 class="text-xl font-semibold mb-4 text-gray-900">Show Up On Time</h3>
                    <p class="text-gray-600">
                        If the pickup window is 2:15, we're there at 2:10. Surgical schedules don't flex because a driver hit traffic.
                        We plan for that.
                    </p>
                </div>
                <div class="bg-white p-6 rounded-lg shadow-sm text-center">
                    <div class="w-16 h-16 bg-primary/10 rounded-full flex items-center justify-center mx-auto mb-4">
                        <iconify-icon icon="heroicons:document-check" width="32" height="32" class="text-primary"></iconify-icon>
                    </div>
                    <h3 class="text-xl font-semibold mb-4 text-gray-900">Document Everything</h3>
                    <p class="text-gray-600">
                        Chain of custody, photo verification, temperature logs when needed. If something goes sideways, there's a paper
                        trail. That's the point.
                    </p>
                </div>
                <div class="bg-white p-6 rounded-lg shadow-sm text-center">
                    <div class="w-16 h-16 bg-primary/10 rounded-full flex items-center justify-center mx-auto mb-4">
                        <iconify-icon icon="heroicons:phone" width="32" height="32" class="text-primary"></iconify-icon>
                    </div>
                    <h3 class="text-xl font-semibold mb-4 text-gray-900">Pick Up the Phone</h3>
                    <p class="text-gray-600">
                        You call, a real person answers. Not a menu, not a chatbot, not a callback in 24 hours. We answer because that's
                        what matters when a case is on the line.
                    </p>
                </div>
            </div>
        </div>
    </section>

    <!-- Why Trius -->
    <section class="py-20 bg-white">
        <div class="max-w-6xl mx-auto px-4 lg:px-6">
            <div class="mb-16">
                <span class="inline-block text-xs font-bold uppercase tracking-[0.2em] text-primary mb-4">Why Trius</span>
                <h2 class="text-3xl md:text-4xl font-black text-slate-900 leading-tight max-w-2xl">
                    We haul medical cargo.<br class="hidden sm:block" /> That's it. That's the whole company.
                </h2>
            </div>

            <div class="grid md:grid-cols-2 gap-x-12 gap-y-10">
                <div class="flex gap-5">
                    <div class="w-12 h-12 rounded-xl bg-primary/10 flex items-center justify-center flex-shrink-0 mt-1">
                        <iconify-icon icon="heroicons:beaker" width="24" height="24" class="text-primary"></iconify-icon>
                    </div>
                    <div>
                        <h3 class="text-lg font-bold text-slate-900 mb-2">Healthcare-only fleet</h3>
                        <p class="text-slate-600 leading-relaxed">
                            No pizza. No parcels. Our vans carry specimens, implant trays, and surgical instruments, and nothing else rides alongside them.
                        </p>
                    </div>
                </div>

                <div class="flex gap-5">
                    <div class="w-12 h-12 rounded-xl bg-primary/10 flex items-center justify-center flex-shrink-0 mt-1">
                        <iconify-icon icon="heroicons:map" width="24" height="24" class="text-primary"></iconify-icon>
                    </div>
                    <div>
                        <h3 class="text-lg font-bold text-slate-900 mb-2">Five states, one team</h3>
                        <p class="text-slate-600 leading-relaxed">
                            WA, OR, ID, MT, Northern CA. We know which docks lock at 6 PM, which labs need a code, and where the freight elevator actually is.
                        </p>
                    </div>
                </div>

                <div class="flex gap-5">
                    <div class="w-12 h-12 rounded-xl bg-accent/10 flex items-center justify-center flex-shrink-0 mt-1">
                        <iconify-icon icon="heroicons:phone-arrow-up-right" width="24" height="24" class="text-accent"></iconify-icon>
                    </div>
                    <div>
                        <h3 class="text-lg font-bold text-slate-900 mb-2">We answer at 3 AM</h3>
                        <p class="text-slate-600 leading-relaxed">
                            Saturday implant case. Holiday organ retrieval. Middle-of-the-night STAT. Someone picks up and a driver dispatches, every time.
                        </p>
                    </div>
                </div>

                <div class="flex gap-5">
                    <div class="w-12 h-12 rounded-xl bg-secondary/10 flex items-center justify-center flex-shrink-0 mt-1">
                        <iconify-icon icon="heroicons:receipt-percent" width="24" height="24" class="text-secondary-dark"></iconify-icon>
                    </div>
                    <div>
                        <h3 class="text-lg font-bold text-slate-900 mb-2">The quote is the price</h3>
                        <p class="text-slate-600 leading-relaxed">
                            No surge fees, no after-hours markups, no line items that weren't in the original conversation. Tuesday rate = Friday midnight rate.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Credentials -->
    <section class="py-20 bg-slate-50 relative overflow-hidden">
        <div class="max-w-6xl mx-auto px-4 lg:px-6 relative z-10">
            <div class="mb-16">
                <span class="inline-block text-xs font-bold uppercase tracking-[0.2em] text-primary mb-4">Credentials</span>
                <h2 class="text-3xl md:text-4xl font-black text-slate-900 leading-tight max-w-3xl">
                    The paperwork that gets us past the badge reader
                </h2>
                <p class="mt-4 text-lg text-slate-500 max-w-2xl">
                    Restricted docks, sterile processing, airside facilities. We carry the clearances so your deliveries don't stall at the front desk.
                </p>
            </div>

            <div class="grid md:grid-cols-2 gap-6">
                <div class="bg-white rounded-2xl border border-slate-200 p-7 flex gap-5">
                    <div class="w-11 h-11 rounded-lg bg-primary flex items-center justify-center flex-shrink-0">
                        <iconify-icon icon="heroicons:shield-check" width="22" height="22" class="text-white"></iconify-icon>
                    </div>
                    <div>
                        <h3 class="text-base font-bold text-slate-900 mb-1.5">TSA Verified</h3>
                        <p class="text-sm text-slate-600 leading-relaxed">
                            Cleared for airports, military installations, and secured healthcare wings where standard couriers get turned away at the gate.
                        </p>
                    </div>
                </div>

                <div class="bg-white rounded-2xl border border-slate-200 p-7 flex gap-5">
                    <div class="w-11 h-11 rounded-lg bg-secondary flex items-center justify-center flex-shrink-0">
                        <iconify-icon icon="heroicons:academic-cap" width="22" height="22" class="text-white"></iconify-icon>
                    </div>
                    <div>
                        <h3 class="text-base font-bold text-slate-900 mb-1.5">SetTrax &amp; Casechek certified</h3>
                        <p class="text-sm text-slate-600 leading-relaxed">
                            We log into the same case management systems your SPD team uses: scan, verify, confirm. No training lag on day one.
                        </p>
                    </div>
                </div>

                <div class="bg-white rounded-2xl border border-slate-200 p-7 flex gap-5">
                    <div class="w-11 h-11 rounded-lg bg-slate-700 flex items-center justify-center flex-shrink-0">
                        <iconify-icon icon="heroicons:document-check" width="22" height="22" class="text-white"></iconify-icon>
                    </div>
                    <div>
                        <h3 class="text-base font-bold text-slate-900 mb-1.5">DOT compliant</h3>
                        <p class="text-sm text-slate-600 leading-relaxed">
                            Interstate-rated vehicles, current inspections, compliant driver records. The boring stuff that matters when cargo crosses state lines.
                        </p>
                    </div>
                </div>

                <div class="bg-white rounded-2xl border border-slate-200 p-7 flex gap-5">
                    <div class="w-11 h-11 rounded-lg bg-accent flex items-center justify-center flex-shrink-0">
                        <iconify-icon icon="heroicons:shield-exclamation" width="22" height="22" class="text-white"></iconify-icon>
                    </div>
                    <div>
                        <h3 class="text-base font-bold text-slate-900 mb-1.5">Fully insured, every run</h3>
                        <p class="text-sm text-slate-600 leading-relaxed">
                            Commercial cargo coverage plus liability on every pickup. A $40K implant tray doesn't ride without a policy behind it.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </section>
    <!-- CTA Section with Background -->
    <section class="relative overflow-hidden">
        <WaveClip
            side="top"
            amplitude={1}
            baseline={95}
            waves={1.25}
            phase={0}
            samples={36}
            topBaseline={10}
            topAmplitude={1}
            topPhase={0}
            class="absolute inset-0 opacity-2 py-24"
        >
            <div class="absolute inset-0 opacity-2">
                <div
                    class="absolute inset-0 min-h-44"
                    style='background-image: url("/Images/Courier handoff.webp"); background-size: cover; background-repeat: no-repeat; background-position: center;'
                >
                </div>
            </div>
            <div class="absolute inset-0 bg-white/60"></div>
        </WaveClip>
        <div class="relative z-10 pt-24">
            <Cta {...ctaData} />
        </div>
    </section>
</Layout>
