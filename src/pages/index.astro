---
import Layout from '@layouts/Layout.astro';
import SEO from '@components/SEO.astro';
import HomeHero from '@components/HomeHero.astro';
import Cards from '@components/Cards.astro';
import TrustSection from '@components/TrustSection.astro';
import Cta from '@components/Cta.astro';
import FAQSection from '@components/FAQSection.astro';
import { graphHome } from '../lib/schema.ts';
import WaveClip from '@components/WaveClip.astro';
import { homeFaqs } from '../data/seoContent';

// Temporary static data for home page (will be replaced with Sanity later)
const heroData = {
    _type: 'heroSection',
    heading: 'Reliable Medical Courier Services You Can Trust',
    body: 'Safe, accurate, and compliant medical courier deliveries for hospitals, laboratories, surgery centers, clinics, and research facilities. We handle STAT specimen transport, scheduled route work, and specialized medical equipment logistics across Washington, Oregon, Idaho, Montana, and California.',
    cta: [
        {
            _key: '1',
            _type: 'actionButton',
            label: 'Request Quote',
            url: '/contact',
            theme: 'primary'
        },
        {
            _key: '2',
            _type: 'actionLink',
            label: 'Our Services',
            url: '/services'
        }
    ]
};

const servicesData = {
    _type: 'cardsSection',
    heading: 'Fast, Secure, and Compliant Medical Transport',
    body: 'From urgent STAT specimen deliveries to scheduled lab routes and specialized equipment transport, Trius supports hospitals, clinics, laboratories, pharmacies, and research teams with secure medical courier service.',
    items: [
        {
            _key: '1',
            heading: 'STAT Deliveries',
            subheading: 'When Every Minute Counts',
            body: 'Urgent transport for specimens, organs, and critical medical equipment, backed by full chain-of-custody verification and real-time tracking.',
            icon: 'heroicons:bolt',
            iconColor: 'accent' as const,
            priority: true,
            features: [
                { icon: 'heroicons:shield-check', text: 'Verified chain of custody' },
                { icon: 'heroicons:map-pin', text: 'Live GPS tracking' },
                { icon: 'heroicons:star', text: 'Priority handling' }
            ],
            cta: [
                {
                    _key: '1',
                    _type: 'actionButton',
                    label: 'Request STAT Delivery',
                    url: '/services/stat-delivery',
                    theme: 'accent'
                }
            ]
        },
        {
            _key: '2',
            heading: 'Scheduled Routes',
            subheading: 'Reliable, Recurring Transport',
            body: 'Trusted daily and weekly pickups for clinics, labs, and research centers with ongoing logistical needs.',
            icon: 'heroicons:calendar-days',
            iconColor: 'primary' as const,
            features: [
                { icon: 'heroicons:map', text: 'Optimized routing' },
                { icon: 'heroicons:clock', text: 'Flexible scheduling' },
                { icon: 'heroicons:currency-dollar', text: 'Cost-efficient delivery' }
            ],
            cta: [
                {
                    _key: '1',
                    _type: 'actionButton',
                    label: 'Schedule My Route',
                    url: '/services/scheduled-routes',
                    theme: 'primary'
                }
            ]
        },
        {
            _key: '3',
            heading: 'Specialized Equipment Transport',
            subheading: 'Expert Handling for Sensitive Devices',
            body: 'Secure movement of regulated, fragile, or temperature-sensitive medical equipment by trained professionals.',
            icon: 'heroicons:truck',
            iconColor: 'secondary' as const,
            features: [
                { icon: 'heroicons:beaker', text: 'Temperature-controlled vehicles' },
                { icon: 'heroicons:hand-raised', text: 'Specialized packaging & handling' },
                { icon: 'heroicons:shield-exclamation', text: 'Secure fleet' }
            ],
            cta: [
                {
                    _key: '1',
                    _type: 'actionButton',
                    label: 'Book Equipment Transport',
                    url: '/services/specialized-equipment',
                    theme: 'secondary'
                }
            ]
        }
    ]
};

const ctaData = {
    _type: 'ctaSection',
    heading: 'Get a Secure Medical Courier Partner Today',
    body: 'Join 150+ healthcare organizations that trust Trius for their critical medical logistics. Start with a free, customized quote and experience delivery excellence.',
    cta: [
        {
            _key: '1',
            _type: 'actionButton',
            label: 'Get Your Free Quote',
            url: '/contact',
            theme: 'primary'
        },
        {
            _key: '2',
            _type: 'actionLink',
            label: 'Learn About Our Process',
            url: '/services',
            theme: 'secondary'
        }
    ]
};

const facilitiesServed = [
    'Hospitals and health systems',
    'Laboratories and diagnostic centers',
    'Clinics and physician offices',
    'Ambulatory surgery centers',
    'Pharmacies and infusion teams',
    'Research and life sciences operations',
    'Medical device representatives',
    'Imaging and specialty care groups'
];

const deliveryTypes = [
    'Medical specimens and lab samples',
    'Bloodwork, pathology materials, and test kits',
    'Pharmaceuticals and temperature-sensitive packages',
    'Surgical instruments and implant support',
    'Diagnostic devices and sensitive equipment',
    'Interoffice transfers between healthcare locations',
    'Emergency STAT pickups with chain of custody',
    'Recurring route-based medical logistics'
];

const schema = graphHome();
---

<Layout
    title="Medical Courier Services | Trius LLC"
    description="Medical courier services for hospitals, labs, clinics, surgery centers, pharmacies, and research teams. Trius handles STAT specimen transport, scheduled routes, and medical equipment delivery across Washington, Oregon, Idaho, Montana, and Northern California."
    image={{ src: '/og-image.png' }}
>
    <Fragment slot="head">
        <SEO
            title="Medical Courier Services | Trius LLC"
            description="Medical courier services for hospitals, labs, clinics, surgery centers, pharmacies, and research teams. Trius handles STAT specimen transport, scheduled routes, and medical equipment delivery across Washington, Oregon, Idaho, Montana, and Northern California."
            graph={schema}
        />
    </Fragment>

    <HomeHero {...heroData} />

    <!-- Services Section with Background -->
    <section class="md:py-20 relative overflow-hidden">
        <!-- Desktop WaveClip Background -->
        <WaveClip
            side="both"
            amplitude={2}
            baseline={95}
            waves={1.7}
            phase={0}
            samples={36}
            topBaseline={10}
            topAmplitude={1}
            topPhase={0}
            class="absolute inset-0 opacity-2 md:py-24 hidden md:block"
        >
            <div
                class="absolute inset-0 min-h-44"
                style='background-image: url("/Images/medical monitor equip.webp"); background-size: cover; 
                background-repeat: no-repeat; background-position: center;'
            >
            </div>
            <div class='absolute inset-0 bg-white/60'></div>
        </WaveClip>

        <!-- Mobile Simple Background -->
        <div class="absolute inset-0 lg:hidden bg-gradient-to-br from-white via-primary/4 to-secondary/4"></div>
        <!-- White overlay for better readability -->

        <div class="relative z-10 md:py-24">
            <Cards {...servicesData} />

            <!-- Trust Proof Element -->
            <div class="text-center my-8">
                <div class="bg-white/95 backdrop-blur-sm rounded-2xl p-8 shadow-lg border border-white/30 max-w-2xl mx-auto">
                    <div class="flex items-center justify-center gap-4 mb-4">
                        <span class="text-xl font-bold text-primary">Trusted by 150+ Healthcare Organizations</span>
                    </div>
                    <p class="text-sm text-base-content/70 font-medium">
                        From small clinics to major hospitals across Washington, Oregon, Idaho, Montana, and California
                    </p>
                    <div class="mt-6">
                        <a href="/contact" class="btn btn-primary btn-lg px-8 py-3 font-bold transition-all duration-300">
                            Get Started Today
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <TrustSection />

    <section class="py-20 bg-white">
        <div class="max-w-7xl mx-auto px-4 lg:px-6">
            <div class="text-center max-w-4xl mx-auto">
                <div
                    class="inline-flex items-center gap-2 rounded-full border border-primary/15 bg-primary/5 px-4 py-2 text-xs font-bold tracking-[0.16em] uppercase text-primary"
                >
                    <iconify-icon icon="heroicons:building-office-2" width="18" height="18"></iconify-icon>
                    Healthcare Delivery Coverage
                </div>
                <h2 class="mt-5 text-3xl md:text-4xl lg:text-5xl font-black text-slate-900 leading-tight">
                    Medical Courier Support for the Facilities and Deliveries That Keep Healthcare Moving
                </h2>
                <p class="mt-6 text-lg leading-8 text-slate-600">
                    Trius is built for healthcare logistics, so the service scope is clear: urgent medical courier support, scheduled route
                    coverage, and specialized handling for sensitive deliveries across Washington, Oregon, Idaho, Montana, and Northern
                    California.
                </p>
            </div>

            <div class="mt-12 grid gap-8 lg:grid-cols-2">
                <article class="flex flex-col rounded-[2rem] border border-slate-200 bg-slate-50/80 p-8 shadow-[0_24px_80px_-56px_rgba(15,23,42,0.35)]">
                    <div
                        class="inline-flex items-center gap-2 rounded-full border border-primary/10 bg-white px-4 py-2 text-xs font-bold tracking-[0.14em] uppercase text-primary w-fit"
                    >
                        <iconify-icon icon="heroicons:user-group" width="18" height="18"></iconify-icon>
                        Facilities We Serve
                    </div>
                    <h3 class="mt-5 text-2xl font-black text-slate-900 min-h-[4rem] lg:min-h-[3.5rem]">Healthcare organizations that need dependable courier coverage</h3>
                    <p class="mt-4 text-base leading-7 text-slate-600 min-h-[3.5rem]">
                        We support healthcare operations where timing, accountability, and handling standards matter more than generic
                        parcel delivery.
                    </p>
                    <ul class="mt-6 grid gap-3 sm:grid-cols-2 sm:grid-rows-4 flex-grow">
                        {
                            facilitiesServed.map((item) => (
                                <li class="flex items-center rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm font-semibold text-slate-700 min-h-[4rem]">
                                    {item}
                                </li>
                            ))
                        }
                    </ul>
                </article>

                <article class="flex flex-col rounded-[2rem] border border-slate-200 bg-slate-50/80 p-8 shadow-[0_24px_80px_-56px_rgba(15,23,42,0.35)]">
                    <div
                        class="inline-flex items-center gap-2 rounded-full border border-secondary/15 bg-white px-4 py-2 text-xs font-bold tracking-[0.14em] uppercase text-secondary-dark w-fit"
                    >
                        <iconify-icon icon="heroicons:archive-box" width="18" height="18"></iconify-icon>
                        What We Transport
                    </div>
                    <h3 class="mt-5 text-2xl font-black text-slate-900 min-h-[4rem] lg:min-h-[3.5rem]">Common medical deliveries handled by Trius</h3>
                    <p class="mt-4 text-base leading-7 text-slate-600 min-h-[3.5rem]">
                        From routine route work to urgent handoffs, Trius stays focused on healthcare-specific deliveries and documented
                        transfer protocols.
                    </p>
                    <ul class="mt-6 grid gap-3 sm:grid-cols-2 sm:grid-rows-4 flex-grow">
                        {
                            deliveryTypes.map((item) => (
                                <li class="flex items-center rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm font-semibold text-slate-700 min-h-[4rem]">
                                    {item}
                                </li>
                            ))
                        }
                    </ul>
                </article>
            </div>

            <div class="mt-10 flex flex-wrap justify-center gap-3">
                <a
                    href="/services/stat-delivery"
                    class="rounded-full border border-accent/20 bg-accent/5 px-5 py-3 text-sm font-bold text-accent transition-colors hover:bg-accent/10"
                >
                    STAT medical courier service
                </a>
                <a
                    href="/services/scheduled-routes"
                    class="rounded-full border border-primary/20 bg-primary/5 px-5 py-3 text-sm font-bold text-primary transition-colors hover:bg-primary/10"
                >
                    scheduled medical routes
                </a>
                <a
                    href="/services/specialized-equipment"
                    class="rounded-full border border-secondary/20 bg-secondary/5 px-5 py-3 text-sm font-bold text-secondary-dark transition-colors hover:bg-secondary/10"
                >
                    medical equipment transport
                </a>
                <a
                    href="/coverage"
                    class="rounded-full border border-slate-200 bg-slate-100 px-5 py-3 text-sm font-bold text-slate-700 transition-colors hover:bg-slate-200"
                >
                    Pacific Northwest coverage
                </a>
            </div>
        </div>
    </section>

    <FAQSection
        heading="Answers to Common Medical Courier Questions"
        intro="Clear answers about service area, delivery types, STAT availability, and recurring routes for healthcare teams evaluating Trius."
        items={homeFaqs}
    />

    <!-- CTA Section with Background -->
    <section class="relative overflow-hidden">
        <!-- Desktop WaveClip Background -->
        <WaveClip
            side="top"
            amplitude={1}
            baseline={95}
            waves={1.25}
            phase={0}
            samples={36}
            topBaseline={10}
            topAmplitude={1}
            topPhase={0}
            class="absolute inset-0 opacity-2 py-24 hidden lg:block"
        >
            <div class='absolute inset-0 opacity-2'>
                <div
                    class="absolute inset-0 min-h-44"
                    style='background-image: url("/Images/personal box deliver.webp"); background-size: cover; background-repeat: no-repeat; background-position: center;'
                >
                </div>
            </div>
            <div class='absolute inset-0 bg-white/60'></div>
        </WaveClip>

        <!-- Mobile Simple Background -->
        <div class="absolute inset-0 lg:hidden bg-gradient-to-br from-slate-50 via-primary/4 to-secondary/4"></div>
        <div class="relative z-10 pt-24">
            <Cta {...ctaData} />
        </div>
    </section>
</Layout>
