---
import Layout from '@layouts/Layout.astro';
import SEO from '@components/SEO.astro';
import Hero from '@components/Hero.astro';
import Cards from '@components/Cards.astro';
import Section from '@components/Section.astro';
import Cta from '@components/Cta.astro';
import WaveClip from '@components/WaveClip.astro';
import { graphServiceEquipment } from '../../lib/schema.ts';

const capabilitiesData = {
    _type: 'cardsSection',
    heading: 'Equipment Transport Capabilities',
    body: 'Our specialized equipment transport service handles delicate, regulated, and high-value medical devices with expert care, secure packaging, and documented handoff procedures.',
    items: [
        {
            _key: '1',
            heading: 'Temperature Control',
            body: 'Climate-controlled vehicles and specialized packaging for temperature-sensitive medical equipment and pharmaceuticals.',
            icon: 'mdi:thermometer',
            iconColor: 'primary' as const,
            features: [
                { icon: 'mdi:snowflake', text: 'Refrigerated transport (2-8°C)' },
                { icon: 'mdi:fire', text: 'Heated transport options' },
                { icon: 'mdi:chart-line', text: 'Temperature monitoring & logging' }
            ]
        },
        {
            _key: '2',
            heading: 'Fragile Handling',
            body: 'Specialized training and equipment for transporting delicate medical instruments and sensitive diagnostic equipment.',
            icon: 'mdi:hand-heart',
            iconColor: 'accent' as const,
            features: [
                { icon: 'mdi:package-variant', text: 'Custom packaging solutions' },
                { icon: 'mdi:account-hard-hat', text: 'Certified handling technicians' },
                { icon: 'mdi:shield-check', text: 'Shock & vibration protection' }
            ]
        },
        {
            _key: '3',
            heading: 'Secure Transport',
            body: 'High-value equipment transport with enhanced security measures and comprehensive insurance coverage.',
            icon: 'mdi:shield-lock',
            iconColor: 'secondary' as const,
            features: [
                { icon: 'mdi:lock', text: 'Secure vehicle locks' },
                { icon: 'mdi:cctv', text: 'GPS tracking & monitoring' },
                { icon: 'mdi:shield-account', text: 'Bonded & insured transport' }
            ]
        }
    ]
};

const equipmentTypesData = {
    _type: 'cardsSection',
    columns: 'two' as const,
    heading: 'Equipment Types We Handle',
    body: 'From small diagnostic devices and surgical instruments to larger imaging and laboratory systems, we handle a wide range of medical equipment for healthcare facilities and vendors.',
    items: [
        {
            _key: '1',
            heading: 'Diagnostic Equipment',
            body: 'Precise handling of sensitive diagnostic instruments including analyzers, scanners, and testing equipment.',
            icon: 'mdi:monitor-dashboard',
            features: [
                { icon: 'mdi:test-tube', text: 'Laboratory analyzers' },
                { icon: 'mdi:camera', text: 'Portable X-ray equipment' },
                { icon: 'mdi:heart-pulse', text: 'Ultrasound machines' },
                { icon: 'mdi:heart-flash', text: 'ECG/EKG equipment' }
            ]
        },
        {
            _key: '2',
            heading: 'Surgical Instruments',
            body: 'Sterile transport of surgical instruments and specialized medical tools with contamination prevention.',
            icon: 'mdi:medical-bag',
            features: [
                { icon: 'mdi:medical-bag', text: 'Sterile instrument sets' },
                { icon: 'mdi:robot', text: 'Robotic surgery components' },
                { icon: 'mdi:magnify', text: 'Microsurgical instruments' },
                { icon: 'mdi:heart', text: 'Implantable devices' }
            ]
        },
        {
            _key: '3',
            heading: 'Imaging Equipment',
            body: 'Large equipment transport including MRI components, CT scan parts, and other heavy medical imaging devices.',
            icon: 'mdi:image-multiple',
            features: [
                { icon: 'mdi:magnet', text: 'MRI machine components' },
                { icon: 'mdi:scan-helper', text: 'CT scanner parts' },
                { icon: 'mdi:account-search', text: 'Mammography equipment' },
                { icon: 'mdi:camera-iris', text: 'Digital radiography systems' }
            ]
        },
        {
            _key: '4',
            heading: 'Laboratory Equipment',
            body: 'Specialized handling for laboratory instruments including centrifuges, microscopes, and analytical equipment.',
            icon: 'mdi:flask',
            features: [
                { icon: 'mdi:rotate-360', text: 'High-speed centrifuges' },
                { icon: 'mdi:microscope', text: 'Electron microscopes' },
                { icon: 'mdi:wave', text: 'Spectrophotometers' },
                { icon: 'mdi:dna', text: 'PCR machines' }
            ]
        }
    ]
};

const safetyData = {
    _type: 'section',
    heading: 'Safety & Compliance Standards',
    body: 'Our equipment transport service meets the highest industry standards for safety, compliance, and equipment protection.'
};

const ctaData = {
    _type: 'ctaSection',
    heading: 'Need Specialized Equipment Transport?',
    body: 'Trust your valuable medical equipment to our trained professionals. Contact us for a customized transport solution.',
    cta: [
        {
            _key: '1',
            _type: 'actionButton',
            label: 'Get Equipment Quote',
            url: '/contact?service=equipment',
            theme: 'primary'
        },
        {
            _key: '2',
            _type: 'actionButton',
            label: 'Call for Consultation',
            url: 'tel:1-800-TRIUS-LLC',
            theme: 'secondary'
        }
    ]
};

const schema = graphServiceEquipment();
---

<Layout
    title='Specialized Medical Equipment Transport | Trius LLC'
    description='Expert transport of fragile medical equipment, imaging systems, surgical instruments, and diagnostic devices with temperature control, secure handling, and specialized packaging.'
    image={{ src: "/og-image.png" }}
>
    <Fragment slot='head'>
        <SEO
            title='Specialized Medical Equipment Transport | Trius LLC'
            description='Expert transport of fragile medical equipment, imaging systems, surgical instruments, and diagnostic devices with temperature control, secure handling, and specialized packaging.'
            graph={schema}
        />
    </Fragment>

    <Hero
        backgroundImage='/Images/medical monitor equip.webp'
        overlayClass='bg-gradient-to-r from-primary/80 via-primary/60 to-secondary/70'
        minHeight='min-h-[70vh]'
        useWaveClip={true}
        waveConfig={{
            side: 'bottom',
            amplitude: 1.5,
            baseline: 95,
            waves: 1.2,
            phase: 0,
            samples: 36
        }}
    >
        <div class='text-center max-w-5xl mx-auto'>
            <!-- Page Badge -->
            <div class='inline-flex items-center gap-3 mb-8 px-6 py-3 bg-white/20 backdrop-blur-sm rounded-full border border-white/30'>
                <iconify-icon icon='heroicons:cube' width='24' height='24' style='color: white;'></iconify-icon>
                <span class='text-white font-bold tracking-wide uppercase'>Specialized Service</span>
            </div>

            <!-- Main Title -->
            <h1 class='text-4xl lg:text-6xl font-black text-white mb-6 leading-tight'>Specialized Medical Equipment Transport</h1>

            <!-- Subtitle -->
            <div class='flex flex-wrap justify-center gap-4 mb-8 text-white/90 font-medium'>
                <span class='flex items-center gap-2'>
                    <iconify-icon icon='heroicons:beaker' width='20' height='20'></iconify-icon>
                    Temperature Control
                </span>
                <span class='flex items-center gap-2'>
                    <iconify-icon icon='heroicons:shield-exclamation' width='20' height='20'></iconify-icon>
                    Hazmat Certified
                </span>
                <span class='flex items-center gap-2'>
                    <iconify-icon icon='heroicons:truck' width='20' height='20'></iconify-icon>
                    Specialized Vehicles
                </span>
            </div>

            <!-- Description -->
            <p class='text-xl lg:text-2xl text-white/90 mb-10 max-w-4xl mx-auto leading-relaxed'>
                Expert handling of fragile medical equipment, temperature-sensitive devices, imaging components, and regulated materials.
                Our trained technicians use specialized vehicles and industry best practices to ensure safe delivery.
            </p>

            <!-- Action Buttons -->
            <div class='flex flex-col sm:flex-row gap-4 justify-center items-center'>
                <a
                    href='/contact?service=equipment'
                    class='btn btn-primary btn-lg px-8 py-4 text-lg font-bold hover:scale-105 transition-all duration-300'
                >
                    Get Equipment Quote
                </a>
                <a
                    href='tel:1-800-TRIUS-LLC'
                    class='text-white font-semibold hover:text-primary-light transition-colors duration-300 flex items-center gap-2'
                >
                    Call for Consultation
                    <iconify-icon icon='heroicons:phone' width='20' height='20'></iconify-icon>
                </a>
            </div>
        </div>
    </Hero>

    <section class='py-20 bg-white'>
        <div class='max-w-7xl mx-auto px-4 lg:px-6'>
            <div class='grid grid-cols-1 lg:grid-cols-[1.05fr_0.95fr] gap-10 lg:gap-14 items-center'>
                <div class='order-2 lg:order-1'>
                    <div class='inline-flex items-center gap-2 rounded-full border border-primary/15 bg-primary/5 px-4 py-2 text-xs font-bold tracking-[0.16em] uppercase text-primary'>
                        <iconify-icon icon='mdi:account-hard-hat' width='18' height='18'></iconify-icon>
                        Field Handling
                    </div>
                    <h2 class='mt-5 text-3xl md:text-4xl font-black text-slate-900 leading-tight'>
                        Real Equipment Handoffs Need More Than a Standard Courier Workflow
                    </h2>
                    <p class='mt-5 text-lg leading-8 text-slate-600 max-w-2xl'>
                        Specialized equipment moves require trained handling, controlled transfer, and direct accountability at pickup and delivery.
                        This is the kind of handoff where condition, packaging, timing, and signoff all matter.
                    </p>

                    <div class='mt-8 grid grid-cols-1 sm:grid-cols-2 gap-4'>
                        <div class='rounded-2xl border border-slate-200 bg-slate-50 p-5'>
                            <div class='text-sm font-bold uppercase tracking-[0.14em] text-primary'>Protected Transfer</div>
                            <p class='mt-2 text-sm leading-6 text-slate-600'>
                                Sensitive components are moved with controlled handling instead of being treated like routine parcel freight.
                            </p>
                        </div>
                        <div class='rounded-2xl border border-slate-200 bg-slate-50 p-5'>
                            <div class='text-sm font-bold uppercase tracking-[0.14em] text-secondary'>Chain of Responsibility</div>
                            <p class='mt-2 text-sm leading-6 text-slate-600'>
                                We maintain clear handoff points so facilities know exactly who received the equipment and when.
                            </p>
                        </div>
                    </div>
                </div>

                <div class='order-1 lg:order-2'>
                    <div class='relative mx-auto max-w-md'>
                        <div class='absolute -inset-4 rounded-[2rem] bg-gradient-to-br from-primary/12 via-transparent to-secondary/12 blur-2xl'></div>
                        <figure class='relative rounded-[2rem] border border-slate-200 bg-white p-3 shadow-[0_30px_80px_-40px_rgba(15,23,42,0.45)]'>
                            <div class='relative overflow-hidden rounded-[1.4rem] bg-slate-100 aspect-[4/5]'>
                                <img
                                    src='/handoff.webp'
                                    alt='Trius team members coordinating a medical equipment handoff in a healthcare facility'
                                    class='absolute top-1/2 left-1/2 block h-auto w-[135%] max-w-none -translate-x-1/2 -translate-y-1/2 rotate-90 transform'
                                    loading='lazy'
                                />
                            </div>
                            <figcaption class='flex items-center justify-between gap-4 px-2 pt-4 pb-1'>
                                <div>
                                    <div class='text-sm font-bold text-slate-900'>Equipment Delivery in Practice</div>
                                    <div class='text-sm text-slate-500'>Coordinated handoff for sensitive medical equipment inside a healthcare facility</div>
                                </div>
                                <div class='rounded-full bg-accent/10 px-3 py-1 text-[11px] font-bold uppercase tracking-[0.14em] text-accent'>
                                    On Site
                                </div>
                            </figcaption>
                        </figure>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Capabilities Section with Background -->
    <section class='py-20 relative overflow-hidden'>
     

        <div class='max-w-7xl mx-auto px-4 lg:px-6 relative z-10 py-8'>
            <Cards {...capabilitiesData} />
        </div>
    </section>
    <!-- Equipment Types Section -->
    <section class='py-20 bg-gradient-to-br from-slate-50 via-primary/5 to-secondary/5'>

        
        <div class='max-w-7xl mx-auto px-4 lg:px-6'>
            
            <Cards {...equipmentTypesData} />
        </div>
    </section>

    <!-- Safety & Compliance Section with Background -->
    <section class='py-20 relative overflow-hidden'>
       

        <div class='max-w-7xl mx-auto px-4 lg:px-6 relative z-10 '>
            <div class='text-center mb-12'>
                <h2 class='text-3xl md:text-4xl font-bold text-gray-900 mb-4'>{safetyData.heading}</h2>
                <p class='text-xl text-gray-600'>{safetyData.body}</p>
            </div>

            <div class='grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8'>
                <div class='bg-white p-6 rounded-lg shadow-sm'>
                    <iconify-icon icon='mdi:certificate' class='text-4xl text-primary mb-3 block'></iconify-icon>
                    <h4 class='text-xl font-semibold mb-4 text-gray-900'>Compliance Certifications</h4>
                    <ul class='space-y-2 text-sm'>
                        <li class='flex items-center gap-2'>
                            <iconify-icon icon='mdi:check' class='text-success'></iconify-icon>
                            <span class='text-gray-600'>FDA regulations compliance</span>
                        </li>
                        <li class='flex items-center gap-2'>
                            <iconify-icon icon='mdi:check' class='text-success'></iconify-icon>
                            <span class='text-gray-600'>Privacy and transport requirements</span>
                        </li>
                        <li class='flex items-center gap-2'>
                            <iconify-icon icon='mdi:check' class='text-success'></iconify-icon>
                            <span class='text-gray-600'>Safety standards</span>
                        </li>
                        <li class='flex items-center gap-2'>
                            <iconify-icon icon='mdi:check' class='text-success'></iconify-icon>
                            <span class='text-gray-600'>DOT transportation regulations</span>
                        </li>
                    </ul>
                </div>
                <div class='bg-white p-6 rounded-lg shadow-sm'>
                    <iconify-icon icon='mdi:school' class='text-4xl text-accent mb-3 block'></iconify-icon>
                    <h4 class='text-xl font-semibold mb-4 text-gray-900'>Staff Training</h4>
                    <ul class='space-y-2 text-sm'>
                        <li class='flex items-center gap-2'>
                            <iconify-icon icon='mdi:check' class='text-success'></iconify-icon>
                            <span class='text-gray-600'>Equipment handling certification</span>
                        </li>
                        <li class='flex items-center gap-2'>
                            <iconify-icon icon='mdi:check' class='text-success'></iconify-icon>
                            <span class='text-gray-600'>Hazmat transport training</span>
                        </li>
                        <li class='flex items-center gap-2'>
                            <iconify-icon icon='mdi:check' class='text-success'></iconify-icon>
                            <span class='text-gray-600'>Clean room procedures</span>
                        </li>
                        <li class='flex items-center gap-2'>
                            <iconify-icon icon='mdi:check' class='text-success'></iconify-icon>
                            <span class='text-gray-600'>Emergency response protocols</span>
                        </li>
                    </ul>
                </div>
                <div class='bg-white p-6 rounded-lg shadow-sm'>
                    <iconify-icon icon='mdi:shield-check' class='text-4xl text-secondary-dark mb-3 block'></iconify-icon>
                    <h4 class='text-xl font-semibold mb-4 text-gray-900'>Insurance & Protection</h4>
                    <ul class='space-y-2 text-sm'>
                        <li class='flex items-center gap-2'>
                            <iconify-icon icon='mdi:check' class='text-success'></iconify-icon>
                            <span class='text-gray-600'>Comprehensive cargo insurance</span>
                        </li>
                        <li class='flex items-center gap-2'>
                            <iconify-icon icon='mdi:check' class='text-success'></iconify-icon>
                            <span class='text-gray-600'>Equipment damage protection</span>
                        </li>
                        <li class='flex items-center gap-2'>
                            <iconify-icon icon='mdi:check' class='text-success'></iconify-icon>
                            <span class='text-gray-600'>Liability coverage</span>
                        </li>
                        <li class='flex items-center gap-2'>
                            <iconify-icon icon='mdi:check' class='text-success'></iconify-icon>
                            <span class='text-gray-600'>Transit risk management</span>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </section>

    <!-- CTA Section with Background -->
    <section class='relative overflow-hidden'>
        <WaveClip side='top' amplitude={1} baseline={95} waves={1.25} phase={0} samples={36} class='absolute inset-0 opacity-2 py-24'>
            <div class='absolute inset-0 opacity-2'>
                <div
                    class='absolute inset-0 min-h-44'
                    style='background-image: url("/Images/personal box deliver.webp"); background-size: cover; background-repeat: no-repeat; background-position: center;'
                >
                </div>
            </div>
            <div class='absolute inset-0 bg-white/70'></div>
        </WaveClip>

        <div class='relative z-10 pt-36'>
            <Cta {...ctaData} />
        </div>
    </section>

    <!-- Related Services -->
    <section class='py-16 bg-base-200'>
        <div class='max-w-5xl mx-auto px-4'>
            <h2 class='text-2xl font-bold text-gray-900 text-center mb-8'>Explore Our Other Services</h2>
            <div class='grid md:grid-cols-2 gap-6'>
                <a href='/services/stat-delivery' class='block p-6 bg-white rounded-xl shadow-sm hover:shadow-md transition-shadow border border-gray-100'>
                    <h3 class='text-lg font-semibold text-primary mb-2'>STAT Deliveries</h3>
                    <p class='text-sm text-gray-600'>Rapid, secure transport of specimens, organs, and urgent medical equipment with real-time tracking.</p>
                </a>
                <a href='/services/scheduled-routes' class='block p-6 bg-white rounded-xl shadow-sm hover:shadow-md transition-shadow border border-gray-100'>
                    <h3 class='text-lg font-semibold text-primary mb-2'>Scheduled Routes</h3>
                    <p class='text-sm text-gray-600'>Recurring pickups and deliveries for clinics, labs, and research centers with route optimization.</p>
                </a>
            </div>
        </div>
    </section>
</Layout>
