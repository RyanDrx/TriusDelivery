---
import Layout from '@layouts/Layout.astro';
import SEO from '@components/SEO.astro';
import Hero from '@components/Hero.astro';
import Cards from '@components/Cards.astro';
import Section from '@components/Section.astro';
import Cta from '@components/Cta.astro';
import { graphServiceStat } from '../../lib/schema.ts';

const featuresData = {
    _type: 'cardsSection',
    heading: 'STAT Delivery Features',
    body: 'Our STAT delivery service is designed for the most critical medical logistics needs with specialized handling and rapid response.',
    items: [
        {
            _key: '1',
            heading: 'Emergency Response',
            body: 'Response within 30 minutes for urgent medical specimen and equipment deliveries with priority dispatch.',
            icon: 'mdi:clock-fast',
            iconColor: 'accent' as const,
            features: [
                { icon: 'mdi:phone', text: '24/7 dispatch availability' },
                { icon: 'mdi:timer', text: '30-minute response time' },
                { icon: 'mdi:map-marker-path', text: 'Priority routing system' }
            ]
        },
        {
            _key: '2',
            heading: 'Chain of Custody',
            body: 'Complete documentation and verification at every step to ensure specimen integrity and regulatory compliance.',
            icon: 'mdi:clipboard-check',
            iconColor: 'primary' as const,
            features: [
                { icon: 'mdi:signature', text: 'Digital signature capture' },
                { icon: 'mdi:barcode-scan', text: 'Barcode tracking system' },
                { icon: 'mdi:certificate', text: 'Compliance documentation' }
            ]
        },
        {
            _key: '3',
            heading: 'Real-Time Tracking',
            body: 'GPS tracking and automated notifications keep you informed throughout the entire delivery process.',
            icon: 'mdi:radar',
            iconColor: 'secondary' as const,
            features: [
                { icon: 'mdi:gps-fixed', text: 'GPS location tracking' },
                { icon: 'mdi:bell', text: 'Automated notifications' },
                { icon: 'mdi:eye', text: 'Live delivery updates' }
            ]
        }
    ]
};

const processData = {
    _type: 'cardsSection',
    heading: 'STAT Delivery Process',
    body: 'Our streamlined process ensures rapid response and secure handling for urgent medical deliveries.',
    items: [
        {
            _key: '1',
            heading: '1. Emergency Call',
            body: 'Call our 24/7 STAT line with your urgent delivery requirements. Our dispatch team will immediately assess and assign a courier.',
            icon: 'mdi:phone-alert'
        },
        {
            _key: '2',
            heading: '2. Rapid Dispatch',
            body: 'Within 30 minutes, a certified courier will arrive at the pickup location with appropriate handling equipment.',
            icon: 'mdi:truck-fast'
        },
        {
            _key: '3',
            heading: '3. Secure Transport',
            body: 'Temperature-controlled, secure transport with real-time tracking and chain-of-custody documentation.',
            icon: 'mdi:shield-lock'
        },
        {
            _key: '4',
            heading: '4. Verified Delivery',
            body: 'Digital signature confirmation and immediate notification to all parties upon successful delivery.',
            icon: 'mdi:check-circle'
        }
    ]
};

const specialHandlingData = {
    _type: 'section',
    heading: 'Specialized Handling Capabilities',
    body: 'Our STAT delivery service includes specialized handling for various types of medical materials and equipment.'
};

const ctaData = {
    _type: 'ctaSection',
    heading: 'Need Emergency STAT Delivery?',
    body: 'Our 24/7 STAT service is ready to handle your urgent medical courier needs. Contact us now for immediate dispatch.',
    cta: [
        {
            _key: '1',
            _type: 'actionButton',
            label: 'Call STAT Line',
            url: 'tel:+12532310615',
            theme: 'accent'
        },
        {
            _key: '2',
            _type: 'actionButton',
            label: 'Request Quote',
            url: '/contact?service=stat',
            theme: 'primary'
        }
    ]
};

const schema = graphServiceStat();
---

<Layout
    title="STAT Medical Courier Deliveries | Trius LLC"
    description="Rapid STAT medical courier transport for specimens, bloodwork, organs, pharmaceuticals, and critical medical equipment with chain of custody and real-time tracking. 24/7 emergency service."
    image={{ src: "/og-image.png" }}
>
    <Fragment slot="head">
        <SEO
            title="STAT Medical Courier Deliveries | Trius LLC"
            description="Rapid STAT medical courier transport for specimens, bloodwork, organs, pharmaceuticals, and critical medical equipment with chain of custody and real-time tracking. 24/7 emergency service."
            graph={schema}
        />
    </Fragment>

    <Hero
        backgroundImage="/Images/medical phials.webp"
        overlayClass="bg-gradient-to-r from-accent/80 via-accent/60 to-primary/70"
        minHeight="min-h-[70vh]"
    >
        <div class="text-center max-w-5xl mx-auto">
            <!-- Page Badge -->
            <div class="inline-flex items-center gap-3 mb-8 px-6 py-3 bg-white/20 backdrop-blur-sm rounded-full border border-white/30">
                <iconify-icon icon="heroicons:bolt" width="24" height="24" style="color: white;"></iconify-icon>
                <span class="text-white font-bold tracking-wide uppercase">Emergency Service</span>
            </div>

            <!-- Main Title -->
            <h1 class="text-4xl lg:text-6xl font-black text-white mb-6 leading-tight">STAT Medical Courier Deliveries</h1>

            <!-- Subtitle -->
            <div class="flex flex-wrap justify-center gap-4 mb-8 text-white/90 font-medium">
                <span class="flex items-center gap-2">
                    <iconify-icon icon="heroicons:clock" width="20" height="20"></iconify-icon>
                    30-Minute Response
                </span>
                <span class="flex items-center gap-2">
                    <iconify-icon icon="heroicons:shield-check" width="20" height="20"></iconify-icon>
                    Chain of Custody
                </span>
                <span class="flex items-center gap-2">
                    <iconify-icon icon="heroicons:map-pin" width="20" height="20"></iconify-icon>
                    Real-Time Tracking
                </span>
            </div>

            <!-- Description -->
            <p class="text-xl lg:text-2xl text-white/90 mb-10 max-w-4xl mx-auto leading-relaxed">
                Rapid, secure, and compliant transport for specimens, bloodwork, organs, pharmaceuticals, and urgent medical devices. When
                time is critical, our STAT delivery service provides immediate response with documented chain-of-custody protocols.
            </p>

            <!-- Action Buttons -->
            <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
                <a
                    href="/contact?service=stat"
                    class="btn btn-accent btn-lg px-8 py-4 text-lg font-bold hover:scale-105 transition-all duration-300"
                >
                    Request STAT Service
                </a>
                <a
                    href="tel:+12532310615"
                    class="text-white font-semibold hover:text-accent-light transition-colors duration-300 flex items-center gap-2"
                >
                    Call Emergency Line
                    <iconify-icon icon="heroicons:phone" width="20" height="20"></iconify-icon>
                </a>
            </div>
        </div>
    </Hero>

    <!-- What is STAT Section -->
    <Section>
        <div class="text-center max-w-4xl mx-auto mb-12">
            <div class="inline-flex items-center gap-3 mb-6 px-6 py-3 bg-accent/10 rounded-full border border-accent/20">
                <iconify-icon icon="mdi:medical-cross" width="24" height="24" class="text-accent"></iconify-icon>
                <span class="text-accent font-bold tracking-wide uppercase">Medical Terminology</span>
            </div>
            <h2 class="text-3xl lg:text-4xl font-bold mb-6">What is STAT?</h2>
            <p class="text-lg text-base-content/80 leading-relaxed mb-8">
                <strong>STAT</strong> is a medical term derived from the Latin word "statim," meaning "immediately" or "at once." In medical
                logistics, STAT indicates the highest level of urgency for specimen transport, diagnostic testing, and medical equipment delivery.
            </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-6xl mx-auto">
            <div class="text-center p-6 bg-gradient-to-br from-accent/5 to-accent/10 rounded-xl border border-accent/20">
                <div class="w-16 h-16 bg-accent/20 rounded-full flex items-center justify-center mx-auto mb-4">
                    <iconify-icon icon="mdi:clock-alert" width="32" height="32" class="text-accent"></iconify-icon>
                </div>
                <h3 class="text-xl font-bold mb-3">Immediate Response</h3>
                <p class="text-base-content/70">
                    STAT orders require immediate attention and response, typically within 30 minutes or less. This urgency is critical for
                    time-sensitive medical procedures and emergency situations.
                </p>
            </div>

            <div class="text-center p-6 bg-gradient-to-br from-primary/5 to-primary/10 rounded-xl border border-primary/20">
                <div class="w-16 h-16 bg-primary/20 rounded-full flex items-center justify-center mx-auto mb-4">
                    <iconify-icon icon="mdi:medical-bag" width="32" height="32" class="text-primary"></iconify-icon>
                </div>
                <h3 class="text-xl font-bold mb-3">Medical Priority</h3>
                <p class="text-base-content/70">
                    STAT deliveries take precedence over all other non-emergency medical courier services. They are essential for critical
                    patient care, organ transplants, and emergency diagnostics.
                </p>
            </div>

            <div class="text-center p-6 bg-gradient-to-br from-secondary/5 to-secondary/10 rounded-xl border border-secondary/20">
                <div class="w-16 h-16 bg-secondary/20 rounded-full flex items-center justify-center mx-auto mb-4">
                    <iconify-icon icon="mdi:certificate" width="32" height="32" class="text-secondary-dark"></iconify-icon>
                </div>
                <h3 class="text-xl font-bold mb-3">Regulatory Compliance</h3>
                <p class="text-base-content/70">
                    STAT deliveries must meet strict regulatory requirements including chain of custody, temperature monitoring, and
                    documentation standards for medical specimen integrity.
                </p>
            </div>
        </div>

        <div class="mt-16 rounded-[2rem] border border-slate-200 bg-white shadow-[0_24px_80px_-48px_rgba(15,23,42,0.35)] overflow-hidden">
            <div class="grid grid-cols-1 lg:grid-cols-[0.9fr_1.1fr]">
                <div class="bg-gradient-to-br from-primary via-primary-dark to-secondary-dark px-8 py-10 lg:px-10 lg:py-12 text-white">
                    <div class="inline-flex items-center gap-2 rounded-full border border-white/20 bg-white/10 px-4 py-2 text-xs font-bold tracking-[0.18em] uppercase">
                        <iconify-icon icon="mdi:alarm-light" width="18" height="18"></iconify-icon>
                        Decision Guide
                    </div>
                    <h4 class="mt-6 text-2xl lg:text-3xl font-black leading-tight">When to Use STAT Delivery</h4>
                    <p class="mt-4 text-white/82 text-base lg:text-lg leading-relaxed max-w-xl">
                        Use STAT service when a delay creates clinical risk, disrupts treatment, or compromises specimen integrity. If the item
                        cannot wait for a scheduled run, it belongs in an immediate-response workflow.
                    </p>

                    <div class="mt-8 space-y-4">
                        <div class="border-t border-white/15 pt-4">
                            <div class="text-xs font-bold uppercase tracking-[0.16em] text-white/60">Request STAT When</div>
                            <div class="mt-2 text-base font-semibold">The delivery decision is tied to patient care, diagnosis, or procedure timing.</div>
                        </div>
                        <div class="border-t border-white/15 pt-4">
                            <div class="text-xs font-bold uppercase tracking-[0.16em] text-white/60">Avoid Routine Routing When</div>
                            <div class="mt-2 text-base font-semibold">A missed pickup window would force re-draws, treatment delays, or equipment downtime.</div>
                        </div>
                    </div>
                </div>

                <div class="bg-slate-50/65 px-8 py-8 lg:px-10 lg:py-10">
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                        <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
                            <div class="flex items-center justify-between gap-3">
                                <h5 class="text-base font-bold text-slate-900">Critical Specimens</h5>
                                <span class="rounded-full bg-accent/10 px-3 py-1 text-[11px] font-bold uppercase tracking-[0.14em] text-accent">Immediate</span>
                            </div>
                            <p class="mt-3 text-sm leading-6 text-slate-600">
                                Time-sensitive blood, tissue, or diagnostic samples that must reach the lab without compromising turnaround or viability.
                            </p>
                        </div>

                        <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
                            <div class="flex items-center justify-between gap-3">
                                <h5 class="text-base font-bold text-slate-900">Organs and Tissue</h5>
                                <span class="rounded-full bg-primary/10 px-3 py-1 text-[11px] font-bold uppercase tracking-[0.14em] text-primary">Time Critical</span>
                            </div>
                            <p class="mt-3 text-sm leading-6 text-slate-600">
                                Transplant-related transport where every minute affects coordination, viability, and the downstream care team.
                            </p>
                        </div>

                        <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
                            <div class="flex items-center justify-between gap-3">
                                <h5 class="text-base font-bold text-slate-900">Urgent Equipment</h5>
                                <span class="rounded-full bg-secondary/10 px-3 py-1 text-[11px] font-bold uppercase tracking-[0.14em] text-secondary-dark">Operational</span>
                            </div>
                            <p class="mt-3 text-sm leading-6 text-slate-600">
                                Medical devices, pumps, or specialty components needed to keep procedures on schedule or restore clinical operations.
                            </p>
                        </div>

                        <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
                            <div class="flex items-center justify-between gap-3">
                                <h5 class="text-base font-bold text-slate-900">Pharma and Supplies</h5>
                                <span class="rounded-full bg-red-100 px-3 py-1 text-[11px] font-bold uppercase tracking-[0.14em] text-red-700">Patient Impact</span>
                            </div>
                            <p class="mt-3 text-sm leading-6 text-slate-600">
                                Emergency pharmaceuticals or life-saving supplies needed to prevent treatment interruption or escalation of care.
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </Section>

    <!-- Features Section with Background -->
    <section class="py-20 bg-white relative overflow-hidden">
        <div class="absolute inset-0 opacity-2">
            <div
                class="absolute inset-0"
                style='background-image: url("/Images/med back.webp"); background-size: cover; background-repeat: no-repeat; background-position: center;'
            >
            </div>
        </div>
        <div class="relative z-10">
            <Cards {...featuresData} />
        </div>
    </section>
    <Cards {...processData} />

    <Section {...specialHandlingData}>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
            <div class="bg-base-200 p-6 rounded-lg text-center">
                <iconify-icon icon="mdi:test-tube" class="text-4xl text-accent mb-3"></iconify-icon>
                <h4 class="font-semibold mb-2">Medical Specimens</h4>
                <p class="text-sm">Blood, urine, tissue samples with temperature control</p>
            </div>
            <div class="bg-base-200 p-6 rounded-lg text-center">
                <iconify-icon icon="mdi:heart" class="text-4xl text-primary mb-3"></iconify-icon>
                <h4 class="font-semibold mb-2">Organs & Tissue</h4>
                <p class="text-sm">Time-critical organ transport with specialized handling</p>
            </div>
            <div class="bg-base-200 p-6 rounded-lg text-center">
                <iconify-icon icon="mdi:pill" class="text-4xl text-secondary-dark mb-3"></iconify-icon>
                <h4 class="font-semibold mb-2">Pharmaceuticals</h4>
                <p class="text-sm">Controlled substances and temperature-sensitive medications</p>
            </div>
            <div class="bg-base-200 p-6 rounded-lg text-center">
                <iconify-icon icon="mdi:medical-bag" class="text-4xl text-accent mb-3"></iconify-icon>
                <h4 class="font-semibold mb-2">Medical Equipment</h4>
                <p class="text-sm">Urgent delivery of critical medical devices and supplies</p>
            </div>
        </div>
    </Section>

    <Cta {...ctaData} />

    <!-- Related Services -->
    <section class='py-16 bg-base-200'>
        <div class='max-w-5xl mx-auto px-4'>
            <h2 class='text-2xl font-bold text-gray-900 text-center mb-8'>Explore Our Other Services</h2>
            <div class='grid md:grid-cols-2 gap-6'>
                <a href='/services/scheduled-routes' class='block p-6 bg-white rounded-xl shadow-sm hover:shadow-md transition-shadow border border-gray-100'>
                    <h3 class='text-lg font-semibold text-primary mb-2'>Scheduled Routes</h3>
                    <p class='text-sm text-gray-600'>Recurring pickups and deliveries for clinics, labs, and research centers with route optimization.</p>
                </a>
                <a href='/services/specialized-equipment' class='block p-6 bg-white rounded-xl shadow-sm hover:shadow-md transition-shadow border border-gray-100'>
                    <h3 class='text-lg font-semibold text-primary mb-2'>Specialized Equipment Transport</h3>
                    <p class='text-sm text-gray-600'>Secure delivery of fragile medical devices with trained handlers and temperature control.</p>
                </a>
            </div>
        </div>
    </section>
</Layout>
